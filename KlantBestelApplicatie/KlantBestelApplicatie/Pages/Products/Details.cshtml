@page "{id:int}"
@model KlantBestelApplicatie.Pages.Products.DetailsModel

@if (Model.Product == null)
{
    <p>Product niet gevonden.</p>
}
else
{
    <section class="product-details">
        <div class="product-details-left">
            <div class="product-main-image">
                <img src="@Model.Product.MainImageUrl" alt="@Model.Product.Name" />
            </div>

            <div class="product-thumbnails">
                @foreach (var image in Model.Product.Images)
                {
                    <button type="button" class="thumbnail-button">
                        <img src="@image.ImageUrl" alt="@image.AltText" />
                    </button>
                }
            </div>

            <section class="product-description">
                <h2>Product beschrijving</h2>
                <p>@Model.Product.Description</p>
            </section>

            <section class="product-specifications">
                <h2>Product specificaties</h2>

                <table>
                    <tbody>
                        @foreach (var spec in Model.Product.Specifications)
                        {
                            <tr>
                                <th>@spec.SpecName</th>
                                <td>@spec.SpecValue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>

        <aside class="product-details-right">
            <h1>@Model.Product.Name</h1>

            <p class="product-detail-price">
                € @Model.Product.Price.ToString("0.00")
            </p>

            <form method="post" asp-page-handler="Order" asp-route-id="@Model.Product.Id">
                <label for="amount">Aantal</label>
                <input id="amount" type="number" name="Amount" value="1" min="1" />

                <button type="submit" class="order-button">
                    <i class="fa-solid fa-cart-shopping"></i>
                    Bestellen
                </button>
            </form>
        </aside>
    </section>
    @section Scripts {
        <script>
            const mainImage = document.querySelector(".product-main-image img");
            const thumbnailButtons = document.querySelectorAll(".thumbnail-button img");

            thumbnailButtons.forEach(thumbnail => {
                thumbnail.addEventListener("click", () => {
                    mainImage.src = thumbnail.src;
                    mainImage.alt = thumbnail.alt;
                });
            });
        </script>
    }
}