@page
@model KE03_INTDEV_SE_1_Base.Pages.OrderSuccessModel

<section class="order-success-page">
    <h1>Bestelling geplaatst</h1>

    <p>Je bestelling is succesvol geplaatst.</p>

    <p>Bestelnummer: <strong>@Model.OrderId</strong></p>

    <div class="order-success-actions">
        <a asp-page="/OrderHistory" class="checkout-button">
            Bekijk bestellingen
        </a>

        <a asp-page="/OrderDetails" asp-route-orderId="@Model.OrderId" class="checkout-button">
            Details
        </a>
    </div>
</section>