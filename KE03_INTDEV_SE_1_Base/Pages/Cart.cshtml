@page
@model KE03_INTDEV_SE_1_Base.Pages.CartModel

<section class="cart-page">
    <h1>Winkelwagen</h1>

    @if (TempData["CartMergedMessage"] != null)
    {
        <div id="cartMergedMessage" class="cart-merged-message">
            <span>@TempData["CartMergedMessage"]</span>

            <button type="button" class="cart-merged-close" onclick="document.getElementById('cartMergedMessage').style.display='none'">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    }

    @if (Model.SelectedCustomer != null)
    {
        <p>Winkelwagen van: <strong>@Model.SelectedCustomer.Name</strong></p>
    }
    else
    {
        <p>Winkelwagen</p>
    }

    @if (!Model.CartItems.Any())
    {
        <p>Je winkelwagen is leeg.</p>
    }
    else
    {
        <div class="cart-layout">
            <section class="cart-items">
                @foreach (var cartItem in Model.CartItems)
                {
                    <article class="cart-item-card">
                        <a asp-page="/Products/Details" asp-route-id="@cartItem.Product.Id" class="cart-item-image">
                            <img src="@cartItem.Product.MainImageUrl" alt="@cartItem.Product.Name" />
                        </a>

                        <div class="cart-item-info">
                            <h2>@cartItem.Product.Name</h2>
                            <p>€ @cartItem.Product.Price.ToString("0.00")</p>
                            <form method="post" asp-page-handler="UpdateAmount" asp-route-productId="@cartItem.ProductId" class="cart-amount-form auto-cart-amount-form">
                                <label for="amount-@cartItem.ProductId">Aantal</label>

                                <input id="amount-@cartItem.ProductId"
                                       type="number"
                                       name="amount"
                                       value="@cartItem.Amount"
                                       min="1"
                                       class="cart-amount-input" />
                            </form>
                        </div>

                        <form method="post" asp-page-handler="RemoveFromCart" asp-route-productId="@cartItem.ProductId">
                            <button type="submit" class="cart-delete-button" aria-label="Verwijderen uit winkelwagen">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </article>
                }
            </section>

            <aside class="cart-summary">
                <h2>Overzicht</h2>

                <div class="cart-summary-lines">
                    @foreach (var cartItem in Model.CartItems)
                    {
                        <div class="cart-summary-line">
                            <span>@cartItem.Product.Name</span>
                            <span>€ @((cartItem.Product.Price * cartItem.Amount).ToString("0.00"))</span>
                        </div>
                    }
                </div>

                <div class="cart-summary-total">
                    <span>Totaalprijs</span>
                    <strong>€ @Model.TotalPrice.ToString("0.00")</strong>
                </div>

                <a asp-page="/Checkout" class="checkout-button">
                    Naar kassa
                </a>
            </aside>
        </div>
    }
</section>
@section Scripts {
    <script>
        const cartAmountForms = document.querySelectorAll(".auto-cart-amount-form");

        cartAmountForms.forEach(form => {
            const input = form.querySelector(".cart-amount-input");
            let timer;

            input.addEventListener("input", () => {
                clearTimeout(timer);

                timer = setTimeout(() => {
                    form.submit();
                }, 700);
            });
        });
    </script>
}