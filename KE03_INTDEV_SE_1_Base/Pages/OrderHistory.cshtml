@page
@model KE03_INTDEV_SE_1_Base.Pages.OrderHistoryModel

<section class="order-history-page">
    <h1>Bestelgeschiedenis</h1>

    @if (Model.SelectedCustomer != null)
    {
        <p>Bestellingen van: <strong>@Model.SelectedCustomer.Name</strong></p>
    }

    @if (!Model.Orders.Any())
    {
        <p>Je hebt nog geen bestellingen geplaatst.</p>
    }
    else
    {
        <div class="order-history-list">
            @foreach (var order in Model.Orders)
            {
                <article class="order-history-card">
                    <div class="order-history-header">
                        <h2>Bestelling #@order.Id</h2>
                        <span>@order.OrderDate.ToString("dd-MM-yyyy HH:mm")</span>
                    </div>

                    <p>
                        Bezorgadres:
                        @order.Address @order.HouseNumber,
                        @order.PostalCode @order.City
                    </p>

                    <div class="order-products">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="order-product-line">
                                <span>@item.Product.Name x @item.Amount</span>
                                <span>€ @((item.PriceAtOrder * item.Amount).ToString("0.00"))</span>
                            </div>
                        }
                    </div>

                    <div class="order-history-total">
                        <span>Totaal</span>
                        <strong>€ @order.TotalPrice.ToString("0.00")</strong>
                    </div>
                </article>
            }
        </div>
    }
</section>