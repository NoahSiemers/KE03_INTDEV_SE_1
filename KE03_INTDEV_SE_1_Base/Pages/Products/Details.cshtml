@page "{id:int}"
@model KE03_INTDEV_SE_1_Base.Pages.Products.DetailsModel

@if (TempData["CartMessage"] != null)
{
    <div id="cartSuccessPopup" class="cart-success-popup">
        <div class="cart-popup-header">
            <strong>@TempData["CartMessage"]</strong>
            <a asp-page="/Cart">naar winkelwagen</a>
        </div>

        <div class="cart-popup-items">
            @foreach (var cartItem in Model.CartItems)
            {
                <div class="cart-popup-item">
                    <img src="@cartItem.Product.MainImageUrl" alt="@cartItem.Product.Name" />

                    <div>
                        <p class="cart-popup-product-name">@cartItem.Product.Name</p>
                        <p>€ @cartItem.Product.Price.ToString("0.00")</p>
                        <p>Aantal: @cartItem.Amount</p>
                    </div>
                </div>
            }
        </div>

        <div class="cart-popup-footer">
            <span>Totaalprijs</span>
            <strong>€ @Model.CartTotalPrice.ToString("0.00")</strong>
        </div>
    </div>
}

@if (Model.Product == null)
{
    <p>Product niet gevonden.</p>
}
else
{
    <section class="product-details">
        <div class="product-details-left">
            <div class="product-main-image">
                <img src="@Model.Product.MainImageUrl" alt="@Model.Product.Name" />
            </div>

            <div class="product-thumbnails">
                @foreach (var image in Model.Product.Images)
                {
                    <button type="button" class="thumbnail-button">
                        <img src="@image.ImageUrl" alt="@image.AltText" />
                    </button>
                }
            </div>

            <section class="product-description">
                <h2>Product beschrijving</h2>
                <p>@Model.Product.Description</p>
            </section>

            <section class="product-specifications">
                <h2>Product specificaties</h2>

                <table>
                    <tbody>
                        @foreach (var spec in Model.Product.Specifications)
                        {
                            <tr>
                                <th>@spec.SpecName</th>
                                <td>@spec.SpecValue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>

        <aside class="product-details-right">
            <h1>@Model.Product.Name</h1>

            <p class="product-detail-price">
                € @Model.Product.Price.ToString("0.00")
            </p>

            <form method="post" asp-page-handler="Order" asp-route-id="@Model.Product.Id">
                <label for="amount">Aantal</label>
                <input id="amount" type="number" name="Amount" value="1" min="1" />

                <button type="submit" class="order-button">
                    <i class="fa-solid fa-cart-shopping"></i>
                    In winkelwagen
                </button>
            </form>
        </aside>
    </section>

    @section Scripts {
        <script>
            const cartPopup = document.getElementById("cartSuccessPopup");
            let cartPopupTimer;

            function hideCartPopup() {
                if (!cartPopup) {
                    return;
                }

                cartPopup.style.opacity = "0";

                setTimeout(() => {
                    cartPopup.style.display = "none";
                }, 300);
            }

            function startCartPopupTimer() {
                cartPopupTimer = setTimeout(hideCartPopup, 3000);
            }

            if (cartPopup) {
                startCartPopupTimer();

                cartPopup.addEventListener("mouseenter", () => {
                    clearTimeout(cartPopupTimer);
                });

                cartPopup.addEventListener("mouseleave", () => {
                    startCartPopupTimer();
                });
            }

            const mainImage = document.querySelector(".product-main-image img");
            const thumbnailImages = document.querySelectorAll(".thumbnail-button img");

            thumbnailImages.forEach(thumbnail => {
                thumbnail.addEventListener("click", () => {
                    mainImage.src = thumbnail.src;
                    mainImage.alt = thumbnail.alt;
                });
            });
        </script>
    }
}